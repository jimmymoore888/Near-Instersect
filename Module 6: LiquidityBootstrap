use near_sdk::borsh::{self, BorshDeserialize, BorshSerialize};
use near_sdk::{
    near_bindgen, AccountId, Balance, PanicOnDefault, env,
};

#[derive(BorshDeserialize, BorshSerialize, Clone)]
pub struct LiquidityPosition {
    pub provider: AccountId,
    pub token_a: AccountId,
    pub token_b: AccountId,
    pub amount_a: Balance,
    pub amount_b: Balance,
    pub is_locked: bool,
}

#[near_bindgen]
#[derive(BorshDeserialize, BorshSerialize, PanicOnDefault)]
pub struct LiquidityBootstrap {
    pub positions: Vec<LiquidityPosition>,
}

#[near_bindgen]
impl LiquidityBootstrap {
    #[init]
    pub fn new() -> Self {
        Self {
            positions: Vec::new(),
        }
    }

    /// Add liquidity intent (does NOT execute swap)
    pub fn add_liquidity(
        &mut self,
        token_a: AccountId,
        token_b: AccountId,
        amount_a: Balance,
        amount_b: Balance,
    ) {
        let provider = env::predecessor_account_id();

        assert!(amount_a > 0, "amount_a must be > 0");
        assert!(amount_b > 0, "amount_b must be > 0");
        assert!(token_a != token_b, "Tokens must differ");

        self.positions.push(LiquidityPosition {
            provider,
            token_a,
            token_b,
            amount_a,
            amount_b,
            is_locked: true, // default lock for bootstrap safety
        });
    }

    /// View all liquidity positions
    pub fn get_positions(&self) -> Vec<LiquidityPosition> {
        self.positions.clone()
    }

    /// Unlock liquidity (only provider)
    pub fn unlock_position(&mut self, index: u64) {
        let mut position = self
            .positions
            .get(index as usize)
            .expect("Invalid index")
            .clone();

        assert_eq!(
            position.provider,
            env::predecessor_account_id(),
            "Not authorized"
        );

        position.is_locked = false;
        self.positions[index as usize] = position;
    }

    /// Check if position is locked
    pub fn is_locked(&self, index: u64) -> bool {
        self.positions
            .get(index as usize)
            .expect("Invalid index")
            .is_locked
    }
}
