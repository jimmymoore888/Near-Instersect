use near_sdk::borsh::{self, BorshDeserialize, BorshSerialize};
use near_sdk::{
    near_bindgen, env, AccountId, Balance, PanicOnDefault, Promise,
};

#[derive(BorshDeserialize, BorshSerialize, Clone)]
pub struct VestingSchedule {
    pub recipient: AccountId,
    pub total_amount: Balance,
    pub start_timestamp: u64,
    pub cliff_timestamp: u64,
    pub end_timestamp: u64,
    pub claimed_amount: Balance,
}

#[near_bindgen]
#[derive(BorshDeserialize, BorshSerialize, PanicOnDefault)]
pub struct VestingContract {
    pub schedules: Vec<VestingSchedule>,
}

#[near_bindgen]
impl VestingContract {
    #[init]
    pub fn new() -> Self {
        Self {
            schedules: Vec::new(),
        }
    }

    pub fn add_schedule(
        &mut self,
        recipient: AccountId,
        total_amount: Balance,
        start_timestamp: u64,
        cliff_timestamp: u64,
        end_timestamp: u64,
    ) {
        assert!(total_amount > 0, "Amount must be > 0");
        assert!(start_timestamp <= cliff_timestamp, "Invalid cliff");
        assert!(cliff_timestamp <= end_timestamp, "Invalid duration");

        self.schedules.push(VestingSchedule {
            recipient,
            total_amount,
            start_timestamp,
            cliff_timestamp,
            end_timestamp,
            claimed_amount: 0,
        });
    }

    pub fn claim(&mut self, index: u64) {
        let mut schedule = self
            .schedules
            .get(index as usize)
            .expect("Invalid schedule index")
            .clone();

        assert_eq!(
            schedule.recipient,
            env::predecessor_account_id(),
            "Not authorized"
        );

        let now = env::block_timestamp();

        let vested = self.calculate_vested(&schedule, now);
        let claimable = vested.saturating_sub(schedule.claimed_amount);

        assert!(claimable > 0, "Nothing to claim");

        schedule.claimed_amount += claimable;
        self.schedules[index as usize] = schedule.clone();

        Promise::new(schedule.recipient).transfer(claimable);
    }

    fn calculate_vested(&self, schedule: &VestingSchedule, now: u64) -> Balance {
        if now < schedule.cliff_timestamp {
            return 0;
        }

        if now >= schedule.end_timestamp {
            return schedule.total_amount;
        }

        let elapsed = now - schedule.start_timestamp;
        let duration = schedule.end_timestamp - schedule.start_timestamp;

        (schedule.total_amount as u128 * elapsed as u128 / duration as u128) as u128
    }

    pub fn get_schedule(&self, index: u64) -> VestingSchedule {
        self.schedules
            .get(index as usize)
            .expect("Invalid index")
            .clone()
    }
}
