use near_sdk::{
    near_bindgen, env, AccountId, PanicOnDefault,
};
use near_sdk::borsh::{self, BorshDeserialize, BorshSerialize};

pub type Balance = u128;

#[near_bindgen]
#[derive(BorshDeserialize, BorshSerialize, PanicOnDefault)]
pub struct BurnCap {
    /// Maximum total tokens allowed to be burned
    pub cap: Balance,

    /// Total tokens burned so far
    pub total_burned: Balance,

    /// Contract allowed to execute burns (usually token contract or factory)
    pub authority: AccountId,
}

#[near_bindgen]
impl BurnCap {
    #[init]
    pub fn new(cap: Balance, authority: AccountId) -> Self {
        assert!(cap > 0, "Cap must be > 0");

        Self {
            cap,
            total_burned: 0,
            authority,
        }
    }

    /// Internal invariant check
    fn assert_within_cap(&self, amount: Balance) {
        let new_total = self.total_burned + amount;

        assert!(
            new_total <= self.cap,
            "Burn exceeds cap"
        );
    }

    /// Called BEFORE actual token burn executes
    pub fn validate_and_record_burn(&mut self, amount: Balance) {
        assert_eq!(
            env::predecessor_account_id(),
            self.authority,
            "Unauthorized"
        );

        assert!(amount > 0, "Amount must be > 0");

        self.assert_within_cap(amount);

        self.total_burned += amount;
    }

    /// View remaining burn capacity
    pub fn remaining(&self) -> Balance {
        self.cap - self.total_burned
    }

    /// View full state
    pub fn state(&self) -> (Balance, Balance) {
        (self.total_burned, self.cap)
    }
}
