use near_sdk::borsh::{self, BorshDeserialize, BorshSerialize};
use near_sdk::{near_bindgen, AccountId, PanicOnDefault};

#[derive(BorshDeserialize, BorshSerialize, Clone)]
pub struct RecipientShare {
    pub account_id: AccountId,
    pub percentage: u16, // basis points (10000 = 100%)
}

#[near_bindgen]
#[derive(BorshDeserialize, BorshSerialize, PanicOnDefault)]
pub struct PercentageDistribution {
    pub shares: Vec<RecipientShare>,
}

#[near_bindgen]
impl PercentageDistribution {
    #[init]
    pub fn new(shares: Vec<RecipientShare>) -> Self {
        assert!(!shares.is_empty(), "Shares cannot be empty");

        let total: u32 = shares.iter().map(|s| s.percentage as u32).sum();

        assert_eq!(
            total, 10_000,
            "Total percentage must equal 10000 basis points (100%)"
        );

        for share in &shares {
            assert!(share.percentage > 0, "Zero percentage not allowed");
        }

        Self { shares }
    }

    pub fn get_shares(&self) -> Vec<RecipientShare> {
        self.shares.clone()
    }

    pub fn validate(&self) -> bool {
        let total: u32 = self.shares.iter().map(|s| s.percentage as u32).sum();
        total == 10_000
    }
}
